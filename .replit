modules = ["nodejs-20", "bash"]

[nix]
channel = "stable-25_05"
packages = ["curl"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
