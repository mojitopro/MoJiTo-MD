args = "WhatsApp Bot Server"

[[workflows.workflow]]
name = "WhatsApp Bot Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "MoJiTo Bot"
author = 46119693
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"

[agent]
