modules = ["nodejs-20", "bash"]
run = "npm run dev"

[nix]
channel = "stable-25_05"
packages = ["curl"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "MoJiTo Bot"
author = 46119693
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MoJiTo Bot - Clean"

[[workflows.workflow]]
name = "MoJiTo Bot - Clean"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"
waitForPort = 5000

[agent]
expertMode = true

[[ports]]
localPort = 5000

[deployment]
run = ["sh", "-c", "npm run dev"]
